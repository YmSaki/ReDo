{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true
    },
    "transform": {
      "react": {
        "runtime": "classic",
        "pragma": "h",
        "pragmaFrag": "Fragment",
        "throwIfNamespace": false,
        "importSource": "src/redo/h"
      }
    }
  },
  "module": {
    "type": "es6"
  }
}
